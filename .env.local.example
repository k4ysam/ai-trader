GEMINI_API_KEY=your_gemini_api_key_here
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_API_SECRET=your_alpaca_paper_api_secret

# Community Layer — Phase 2 (Upstash Redis)
# Get these from https://console.upstash.com — use Pay-as-you-go tier
# Free tier exhausted at ~5 concurrent users; PAY at ~$0.20/100k reads
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Set to "true" to enable real community data (requires Upstash env vars above)
# When unset or "false", community panel shows simulated data
NEXT_PUBLIC_COMMUNITY_ENABLED=false

# Community History — Phase 3 (Neon Postgres)
# Get connection string from https://console.neon.tech
# Without this, the History and Comparison tabs show empty state (graceful degradation)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
